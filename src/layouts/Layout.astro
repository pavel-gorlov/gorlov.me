---
import i18next, { t } from "i18next";
import '../assets/styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

// пути для меню
const cvPath = `${i18next.language === 'ru' ? '/ru' : ''}/cv`;
const homePath = i18next.language === 'ru' ? '/ru/' : '/';

// определяем активный путь
const normalize = (p: string) => p.replace(/\/+$/, '');
const currentPath = Astro.url.pathname;
const isHome = normalize(currentPath) === normalize(homePath);
const isCV = normalize(currentPath).startsWith(normalize(cvPath));
---

<!DOCTYPE html>
<html lang={i18next.language}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t('name')} – {t('position')}</title>
  <script src="/src/assets/scripts/main.js" type="module" defer></script>
</head>
<body>

  <!-- Шапка сайта, меню и плейсхолдер фотографии объединены в общую сетку -->
  <header class="site-header">
    <div class="header-text">
      <h1>{t('name')}</h1>
      <h2>{t('position')}</h2>
    </div>

    <div class="photo-placeholder" aria-label="photo placeholder">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" role="img" aria-labelledby="avatarTitle" width="100%" height="100%">
        <title id="avatarTitle">{t('name')}</title>
        <circle cx="64" cy="40" r="24" fill="#e2e8f0" />
        <path d="M16 116c0-26.5 21.5-48 48-48s48 21.5 48 48" fill="#e2e8f0" />
      </svg>
    </div>

    <nav class="site-nav">
      <a href={homePath} aria-current={isHome ? 'page' : undefined} class={isHome ? 'font-semibold underline decoration-wavy' : ''}>{t('menu.home')}</a>
      <a href={cvPath} aria-current={isCV ? 'page' : undefined} class={isCV ? 'font-semibold underline decoration-wavy' : ''}>{t('menu.cv')}</a>
      <ThemeSwitcher />
    </nav>
  </header>

  <slot />

  <!-- Футер с копирайтом -->
  <footer>
    {t('footer.copyright')}
  </footer>

</body>
</html>