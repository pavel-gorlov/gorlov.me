---
// @ts-ignore Astro global is provided at runtime
const currentPath = Astro.url.pathname;
const currentLang = currentPath.startsWith('/ru') ? 'ru' : 'en';

const buildPath = (lang: 'en' | 'ru') => {
  const hasRuPrefix = currentPath.startsWith('/ru');
  if (lang === 'ru') {
    if (hasRuPrefix) return currentPath;
    return `/ru${currentPath}`;
  }
  return hasRuPrefix ? currentPath.replace(/^\/ru/, '') || '/' : currentPath;
};

const langs: Array<{ code: 'en' | 'ru'; flag: string; label: string }> = [
  { code: 'en', flag: '🇺🇸', label: 'EN' },
  { code: 'ru', flag: '🇷🇺', label: 'RU' },
];
---

<div class="lang-switcher" role="group" aria-label="Language selector">
  {langs.map(({ code, flag, label }) => (
    code === currentLang ? (
      <span class="lang-item lang-item-active" aria-current="true">
        <span class="lang-flag" aria-hidden="true">{flag}</span>
        <span class="lang-label">{label}</span>
      </span>
    ) : (
      <a
        href={buildPath(code)}
        class="lang-item"
        data-lang={code}
        hreflang={code}
        aria-label={code === 'ru' ? 'Переключить на русский' : 'Switch to English'}
      >
        <span class="lang-flag" aria-hidden="true">{flag}</span>
        <span class="lang-label">{label}</span>
      </a>
    )
  ))}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .lang-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.3em 0.6em;
    border: 1px solid transparent;
    border-radius: 6px;
    font-size: 0.9em;
    line-height: 1;
    color: var(--footer-link-color);
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  a.lang-item:hover {
    color: var(--link-hover-color);
    background-color: rgba(127, 127, 127, 0.08);
    text-decoration: none;
  }

  .lang-item-active {
    color: var(--text-color);
    border-color: var(--link-color);
    background-color: rgba(127, 127, 127, 0.06);
    cursor: default;
  }

  .lang-flag {
    font-size: 1.1em;
    line-height: 1;
  }

  .lang-label {
    font-weight: 600;
    letter-spacing: 0.4px;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLAnchorElement>('a.lang-item[data-lang]').forEach((link) => {
      link.addEventListener('click', () => {
        const targetLang = link.dataset.lang;
        if (!targetLang) return;
        localStorage.setItem('userLanguageChoice', `manual-${targetLang}`);
        localStorage.removeItem('autoRedirected');
      });
    });
  });
</script>
