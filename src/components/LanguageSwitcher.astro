---
import i18next from "i18next";

// Current pathname (e.g. "/", "/ru/", "/cv", "/ru/cv")
// @ts-ignore Astro global is provided at runtime
const currentPath = Astro.url.pathname;

// Helper: build path for requested lang according to current location
const buildPath = (lang: 'en' | 'ru') => {
  const hasRuPrefix = currentPath.startsWith('/ru');
  if (lang === 'ru') {
    // Already on ru: keep, else add /ru prefix
    if (hasRuPrefix) return currentPath;
    // Avoid duplicating slash for root
    return `/ru${currentPath}`;
  } else {
    // English: remove /ru prefix if exists
    return hasRuPrefix ? currentPath.replace(/^\/ru/, '') || '/' : currentPath;
  }
};

const enPath = buildPath('en');
const ruPath = buildPath('ru');

const currentLang = i18next.language as 'en' | 'ru';
const ruFlag = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" class="w-6 ring-1 ring-gray-300 dark:ring-gray-600"><rect width="60" height="30" fill="#fff"/><rect y="10" width="60" height="10" fill="#0039a6"/><rect y="20" width="60" height="10" fill="#d52b1e"/></svg>';
const enFlag = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" class="w-6 ring-1 ring-gray-300 dark:ring-gray-600"><rect width="60" height="30" fill="#012169"/><path d="M0 0 L60 30 M60 0 L0 30" stroke="#fff" stroke-width="6"/><path d="M0 0 L60 30 M60 0 L0 30" stroke="#C8102E" stroke-width="4"/><path d="M30 0 V30 M0 15 H60" stroke="#fff" stroke-width="10"/><path d="M30 0 V30 M0 15 H60" stroke="#C8102E" stroke-width="6"/></svg>';
---

<details class="relative group" role="list" aria-label="Language selector">
  <summary class="cursor-pointer flex items-center select-none" title={currentLang === 'ru' ? 'Русский' : 'English'}>
    <span set:html={currentLang === 'ru' ? ruFlag : enFlag}></span>
    <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 w-4 text-current transition-transform group-open:-rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" /></svg>
  </summary>
  <ul class="absolute right-0 mt-2 flex flex-col bg-white dark:bg-slate-800 rounded shadow-lg min-w-[6rem] py-1 z-10">
    <li>
      <a href={enPath}
         aria-current={currentLang === 'en' ? 'page' : undefined}
         class={`flex items-center gap-2 px-3 py-1 hover:bg-gray-100 dark:hover:bg-slate-700 ${currentLang === 'en' ? 'opacity-50 pointer-events-none cursor-default' : ''}`}
         > <span set:html={enFlag}></span> <span class="text-sm">English</span></a>
    </li>
    <li>
      <a href={ruPath}
         aria-current={currentLang === 'ru' ? 'page' : undefined}
         class={`flex items-center gap-2 px-3 py-1 hover:bg-gray-100 dark:hover:bg-slate-700 ${currentLang === 'ru' ? 'opacity-50 pointer-events-none cursor-default' : ''}`}> <span set:html={ruFlag}></span> <span class="text-sm">Русский</span></a>
    </li>
  </ul>
</details> 