---
// Current pathname (e.g. "/", "/ru/", "/cv", "/ru/cv")
// @ts-ignore Astro global is provided at runtime
const currentPath = Astro.url.pathname;

// Determine current language from URL path
const currentLang = currentPath.startsWith('/ru') ? 'ru' : 'en';

// Helper: build path for requested lang according to current location
const buildPath = (lang: 'en' | 'ru') => {
  const hasRuPrefix = currentPath.startsWith('/ru');
  if (lang === 'ru') {
    // Already on ru: keep, else add /ru prefix
    if (hasRuPrefix) return currentPath;
    // Avoid duplicating slash for root
    return `/ru${currentPath}`;
  } else {
    // English: remove /ru prefix if exists
    return hasRuPrefix ? currentPath.replace(/^\/ru/, '') || '/' : currentPath;
  }
};

const enPath = buildPath('en');
const ruPath = buildPath('ru');
---

<div class="globe-switcher" data-current-lang={currentLang}>
  <a
    href={currentLang === 'en' ? ruPath : enPath}
    class="globe-container"
    aria-label={currentLang === 'en' ? 'Переключить на русский' : 'Switch to English'}
    title={currentLang === 'en' ? 'Переключить на русский' : 'Switch to English'}>

    <svg class="globe" width="48" height="48" viewBox="0 0 32 32">
      <defs>
        <clipPath id="globe-clip">
          <circle cx="16" cy="16" r="14"/>
        </clipPath>
      </defs>

      <!-- Globe background -->
      <circle cx="16" cy="16" r="14" fill="currentColor" opacity="0.05"/>

      <!-- Continents (simplified shapes) -->
      <g class="continents" clip-path="url(#globe-clip)">
        <!-- North America (left side) -->
        <path d="M 6 10 Q 8 8, 10 10 L 11 12 Q 12 14, 10 16 L 8 18 Q 6 16, 7 14 L 6 10 Z"
              fill="currentColor" opacity="0.2"/>

        <!-- Europe/Africa (center-left) -->
        <path d="M 13 8 L 15 7 L 17 9 L 16 12 Q 15 14, 13 13 L 12 11 Z"
              fill="currentColor" opacity="0.2"/>
        <path d="M 14 14 L 16 15 Q 17 18, 15 20 L 13 21 L 12 18 Q 13 16, 14 14 Z"
              fill="currentColor" opacity="0.2"/>

        <!-- Asia/Russia (right side) -->
        <path d="M 18 6 L 22 7 Q 24 8, 25 10 L 26 13 Q 25 15, 23 14 L 20 12 Q 19 10, 18 8 Z"
              fill="currentColor" opacity="0.2"/>
        <path d="M 20 14 Q 22 16, 24 17 L 26 19 Q 25 21, 23 20 L 21 18 Q 20 16, 20 14 Z"
              fill="currentColor" opacity="0.2"/>

        <!-- Australia (bottom right) -->
        <path d="M 22 22 Q 24 22, 25 24 L 24 25 Q 22 25, 22 23 Z"
              fill="currentColor" opacity="0.2"/>
      </g>

      <!-- Longitude lines -->
      <ellipse cx="16" cy="16" rx="14" ry="14" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" clip-path="url(#globe-clip)"/>
      <ellipse cx="16" cy="16" rx="10" ry="14" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" clip-path="url(#globe-clip)"/>
      <ellipse cx="16" cy="16" rx="5" ry="14" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" clip-path="url(#globe-clip)"/>

      <!-- Latitude lines -->
      <line x1="2" y1="16" x2="30" y2="16" stroke="currentColor" stroke-width="0.5" opacity="0.3"/>
      <ellipse cx="16" cy="16" rx="14" ry="7" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" clip-path="url(#globe-clip)"/>
      <ellipse cx="16" cy="16" rx="14" ry="3.5" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.3" clip-path="url(#globe-clip)"/>

      <!-- Globe outline -->
      <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/>

      <!-- USA marker (left side) -->
      <g class="pin pin-usa">
        <circle cx="8" cy="14" r="2.5" fill="currentColor" opacity="0.9"/>
        <text x="8" y="15.5" text-anchor="middle" font-size="9" fill="var(--bg-color)" font-weight="bold">🇺🇸</text>
      </g>

      <!-- Russia marker (right side) -->
      <g class="pin pin-russia">
        <circle cx="24" cy="12" r="2.5" fill="currentColor" opacity="0.9"/>
        <text x="24" y="13.5" text-anchor="middle" font-size="9" fill="var(--bg-color)" font-weight="bold">🇷🇺</text>
      </g>

      <!-- Language badge (bottom) -->
      <g class="lang-badge">
        <rect x="11" y="26" width="10" height="6" rx="3" fill="currentColor"/>
        <text x="16" y="30.8" text-anchor="middle" font-size="5" font-weight="bold" class="lang-code lang-code-current badge-text">
          {currentLang.toUpperCase()}
        </text>
        <text x="16" y="30.8" text-anchor="middle" font-size="5" font-weight="bold" class="lang-code lang-code-next badge-text" opacity="0">
          {currentLang === 'en' ? 'RU' : 'EN'}
        </text>
      </g>
    </svg>
  </a>
</div>

<style>
  .globe-switcher {
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 100px;
  }

  .globe-container {
    display: block;
    width: 48px;
    height: 48px;
    cursor: pointer;
    color: var(--link-color);
    transition: all 0.3s ease;
    position: relative;
    transform-style: preserve-3d;
  }

  .globe-container:hover {
    color: var(--link-hover-color);
    transform: scale(1.4);
  }

  .globe {
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    transform-style: preserve-3d;
  }

  .globe-container:hover .globe {
    transform: rotateY(180deg);
  }

  .continents {
    transform-origin: center;
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .globe-container:hover .continents {
    transform: scaleX(-1);
  }

  .pin {
    transition: opacity 0.5s ease, transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    transform-origin: center;
  }

  .globe-container:hover .pin {
    transform: scaleX(-1);
  }

  .lang-badge {
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    transform-origin: center;
  }

  .globe-container:hover .lang-badge {
    transform: scaleX(-1);
  }

  .lang-badge rect {
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
  }

  .badge-text {
    fill: var(--bg-color);
  }

  /* Higher contrast for badge text in light theme */
  :root .badge-text {
    fill: #ffffff;
  }

  /* Higher contrast for badge text in dark theme */
  .dark .badge-text {
    fill: #000000;
  }

  .lang-code {
    letter-spacing: 0.3px;
    transition: opacity 0.3s ease;
  }

  .lang-code-current {
    opacity: 1;
  }

  .lang-code-next {
    opacity: 0;
  }

  .globe-container:hover .lang-code-current {
    opacity: 0;
  }

  .globe-container:hover .lang-code-next {
    opacity: 1;
  }

  /* Show USA pin for English, hide Russia pin */
  .globe-switcher[data-current-lang="en"] .pin-usa {
    opacity: 1;
  }

  .globe-switcher[data-current-lang="en"] .pin-russia {
    opacity: 0.3;
  }

  /* Show Russia pin for Russian, hide USA pin */
  .globe-switcher[data-current-lang="ru"] .pin-russia {
    opacity: 1;
  }

  .globe-switcher[data-current-lang="ru"] .pin-usa {
    opacity: 0.3;
  }

  /* Switch active pins on hover */
  .globe-switcher[data-current-lang="en"] .globe-container:hover .pin-usa {
    opacity: 0.3;
  }

  .globe-switcher[data-current-lang="en"] .globe-container:hover .pin-russia {
    opacity: 1;
  }

  .globe-switcher[data-current-lang="ru"] .globe-container:hover .pin-russia {
    opacity: 0.3;
  }

  .globe-switcher[data-current-lang="ru"] .globe-container:hover .pin-usa {
    opacity: 1;
  }

  .pin circle {
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.3));
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const globeLink = document.querySelector('.globe-container');

    if (globeLink) {
      globeLink.addEventListener('click', () => {
        // Save manual language choice to localStorage
        const currentLang = document.querySelector('.globe-switcher')?.getAttribute('data-current-lang');
        const targetLang = currentLang === 'en' ? 'ru' : 'en';

        // Mark this as a manual choice
        localStorage.setItem('userLanguageChoice', `manual-${targetLang}`);
        // Clear any auto-redirect flag
        localStorage.removeItem('autoRedirected');

        const globe = globeLink.querySelector('.globe') as HTMLElement;
        const continents = globeLink.querySelector('.continents') as HTMLElement;
        const pins = globeLink.querySelectorAll('.pin');
        const badge = globeLink.querySelector('.lang-badge') as HTMLElement;

        if (globe) {
          globe.style.transform = 'rotateY(360deg)';

          if (continents) {
            continents.style.transform = 'scaleX(-1)';
          }

          pins.forEach((pin) => {
            (pin as HTMLElement).style.transform = 'scaleX(-1)';
          });

          if (badge) {
            badge.style.transform = 'scaleX(-1)';
          }

          // Reset after animation
          setTimeout(() => {
            globe.style.transform = '';
            if (continents) {
              continents.style.transform = '';
            }
            pins.forEach((pin) => {
              (pin as HTMLElement).style.transform = '';
            });
            if (badge) {
              badge.style.transform = '';
            }
          }, 800);
        }
      });
    }
  });
</script> 