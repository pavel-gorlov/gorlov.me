---
export interface Props {
	name: string;
	position: string;
}
const { name, position } = Astro.props;
---

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-100 via-white to-gray-200">
	<div class="w-full max-w-xl px-10 py-16 flex flex-col items-center bg-white/80">
		<h1 class="text-5xl font-semibold tracking-tight text-gray-900 mb-4 text-center" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">{name}</h1>
		<p class="text-2xl text-gray-500 font-light mb-10 text-center">{position}</p>
		<div class="flex flex-col gap-3 w-full items-center">
			<a href="mailto:gorlov@example.com" class="text-lg text-blue-600 hover:underline transition">gorlov@example.com</a>
			<a href="https://t.me/gorlov" class="text-lg text-blue-600 hover:underline transition">@gorlov (Telegram)</a>
			<a href="https://github.com/gorlov" class="text-lg text-blue-600 hover:underline transition">github.com/gorlov</a>
		</div>
	</div>
</div>

