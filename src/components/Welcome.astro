---
import { t } from "i18next";
---

<!-- Раздел "Обо мне" -->
  <section id="about">
    <h3>{t('about.title')}</h3>
    <p>{t('about.description1')}</p>
    <p>{t('about.description2')}</p>
  </section>

  <!-- Раздел "Проекты" -->
  <section id="projects">
    <h3>{t('projects.title')}</h3>
    <ul>
      <li><strong>SuperProduct X</strong> – {t('projects.items.superproduct')}</li>
      <li><strong>OpenSource Library Y</strong> – {t('projects.items.opensource')}</li>
      <li><strong>Award Z</strong> – {t('projects.items.award')}</li>
    </ul>
  </section>

  <!-- Раздел "Контакты" -->
  <section id="contacts">
    <h3>{t('contacts.title')}</h3>
    <p>{t('contacts.description')}</p>
    <p><strong>{t('contacts.email')}:</strong> <a href="mailto:ivan@example.com">ivan@example.com</a><br/>
       <strong>{t('contacts.linkedin')}:</strong> <a href="#">ivan-ivanov</a><br/>
       <strong>{t('contacts.github')}:</strong> <a href="#">@ivanivanov</a></p>
  </section>
